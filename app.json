{
  "expo": {
    "name": "Whisssper",
    "slug": "whisssper",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#faf8f4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.khizarnomansahir.whisssper",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Whisssper needs microphone access to record your voice entries.",
        "NSSpeechRecognitionUsageDescription": "Whisssper uses speech recognition to transcribe your voice entries."
      }
    },
    "android": {
      "package": "com.khizarnomansahir.whisssper",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": ["expo-router", "expo-av"],
    "scheme": "whisssper",
    "experiments": {
      "typedRoutes": true
    }
  }
}